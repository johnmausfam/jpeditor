              "options": {
                "noEmit": true
              }
            }
          }
        }
      },
      "build-deps": {
        "dependsOn": [
          "^build"
        ]
      },
      "watch-deps": {
        "continuous": true,
        "dependsOn": [
          "build-deps"
        ],
        "command": "npx nx watch --projects web --includeDependentProjects -- npx nx build-deps web"
      }
    },
    "metadata": {},
    "projectType": "application"
  },
